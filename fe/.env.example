# Local development needs no API URL: Vite proxies /auth, /chat, and /health
# to BE1 at http://127.0.0.1:8100.
#
# Set this only when a deployed frontend calls BE1 on another origin.
VITE_API_BASE_URL=http://127.0.0.1:8000

# Optional local proxy override.
VITE_DEV_PROXY_TARGET=http://127.0.0.1:8000

# Bảng "đang suy nghĩ" (tool calling của Agent) hiển thị để debug.
# KHÔNG khai báo (mặc định) -> HIỆN. Đặt False (production) -> ẩn.
# VITE_DEBUG=False
