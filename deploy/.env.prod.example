# Compose interpolation variables for deploy/docker-compose.prod.yml.
# Copy to deploy/.env.prod on the server (gitignored) and fill in real values.
# POSTGRES_PASSWORD MUST match the password embedded in be1/.env DATABASE_URL.

POSTGRES_DB=be1
POSTGRES_USER=be1
POSTGRES_PASSWORD=change-me

# Public ports the SPA/nginx is published on. HTTP redirects to HTTPS.
PUBLIC_HTTP_PORT=80
PUBLIC_HTTPS_PORT=443

# Container memory limits.
ELASTICSEARCH_MEMORY_LIMIT=2g
QDRANT_MEMORY_LIMIT=1g
