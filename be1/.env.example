# 1 = chạy không cần API key (regex/template thay LLM) — để dev/test luồng
MOCK_LLM=1

# OpenAI-compatible: Groq / Fireworks / Together đều dùng được
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=
LLM_MODEL_SMALL=llama-3.3-70b-versatile
LLM_MODEL_LARGE=llama-3.3-70b-versatile

# Rỗng -> dùng fixtures/ local. Trỏ vào BE2 của Kiên khi sẵn sàng.
BE2_BASE_URL=

# Elasticsearch chạy trên host. Khi BE1 chạy trong Compose, dùng:
# ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_URL=http://127.0.0.1:9200
ELASTICSEARCH_PRODUCTS_INDEX=products
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_TIMEOUT_SECONDS=10

# PostgreSQL runs through be1/docker/docker-compose.yml.
# Keep this password aligned with POSTGRES_PASSWORD in docker/.env.docker.
DATABASE_URL=postgresql+asyncpg://be1:change-me@127.0.0.1:5432/be1
DATABASE_ECHO=0
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_RECYCLE_SECONDS=1800

# LangGraph checkpoints use Psycopg 3. Leave blank only if your environment
# injects the same connection as DATABASE_URL without the +asyncpg driver.
LANGGRAPH_DATABASE_URL=postgresql://be1:change-me@127.0.0.1:5432/be1
LANGGRAPH_POOL_MIN_SIZE=1
LANGGRAPH_POOL_MAX_SIZE=5

# Phone/password authentication and failed-login throttling.
APP_ENV=development
PHONE_DEFAULT_REGION=VN
PHONE_ALLOWED_COUNTRY_CODES=84
PASSWORD_MIN_LENGTH=8
PASSWORD_MAX_LENGTH=128
LOGIN_RATE_LIMIT_WINDOW_SECONDS=900
LOGIN_PHONE_RATE_LIMIT_COUNT=5
LOGIN_IP_RATE_LIMIT_COUNT=20
AUTH_RATE_LIMIT_SECRET=replace-with-at-least-32-random-bytes

# JWT signing and revocable refresh-session digests.
JWT_SECRET_KEY=replace-with-at-least-32-random-bytes
AUTH_TOKEN_DIGEST_SECRET=replace-with-another-32-random-bytes
JWT_ISSUER=dmx-advisor-be1
JWT_AUDIENCE=dmx-advisor-web
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000
JWT_LEEWAY_SECONDS=5

# Browser session cookies and credentialed CORS. Use the same hostname for
# Vite and BE1 in development (localhost with localhost, or 127.0.0.1 with it).
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
AUTH_ACCESS_COOKIE_NAME=dmx_access
AUTH_REFRESH_COOKIE_NAME=dmx_refresh
AUTH_COOKIE_SECURE=0
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_DOMAIN=

MAX_ASK_TURNS=3
COMPARE_THRESHOLD=3

# --- RAG chính sách (embedding OpenAI-compatible + Qdrant) ---
# EMBED_MODEL rỗng (hoặc MOCK_LLM=1) -> fallback lexical, chạy offline không cần key/Qdrant.
# Điền tên embedding model của FPT AI Factory để bật RAG bằng embeddings + Qdrant.
EMBED_MODEL=
# Rỗng -> dùng lại LLM_BASE_URL / LLM_API_KEY ở trên.
EMBED_BASE_URL=
EMBED_API_KEY=
RAG_TOP_K=4
RAG_MIN_SCORE=0.3
# Qdrant chạy trên host (docker compose). Khi BE1 chạy trong Compose: QDRANT_URL=http://qdrant:6333
QDRANT_URL=http://127.0.0.1:6333
QDRANT_POLICY_COLLECTION=policies
QDRANT_API_KEY=
QDRANT_TIMEOUT_SECONDS=10

# --- Judge (model ngoài mạnh hơn, chấm hallucination) ---
# MOCK_JUDGE=1: chỉ đối chiếu con số, chạy offline không cần key
MOCK_JUDGE=0
# rỗng -> dùng lại LLM_BASE_URL/LLM_API_KEY/LLM_MODEL_LARGE ở trên
JUDGE_BASE_URL=
JUDGE_API_KEY=
JUDGE_MODEL=

# --- Langfuse (tracing + scores) — điền đủ 2 key là tự bật ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
