# 1 = chạy không cần API key (regex/template thay LLM) — để dev/test luồng
MOCK_LLM=1

# OpenAI-compatible: Groq / Fireworks / Together đều dùng được
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=
LLM_MODEL_SMALL=llama-3.3-70b-versatile
LLM_MODEL_LARGE=llama-3.3-70b-versatile

# Rỗng -> dùng fixtures/ local. Trỏ vào BE2 của Kiên khi sẵn sàng.
BE2_BASE_URL=

MAX_ASK_TURNS=3
COMPARE_THRESHOLD=3

# --- RAG chính sách (embedding OpenAI-compatible) ---
# EMBED_MODEL rỗng (hoặc MOCK_LLM=1) -> fallback tìm kiếm lexical, chạy offline không cần key.
# Điền tên embedding model của FPT AI Factory để bật RAG bằng embeddings.
EMBED_MODEL=
# Rỗng -> dùng lại LLM_BASE_URL / LLM_API_KEY ở trên.
EMBED_BASE_URL=
EMBED_API_KEY=
RAG_TOP_K=4
RAG_MIN_SCORE=0.3

# --- Judge (model ngoài mạnh hơn, chấm hallucination) ---
# MOCK_JUDGE=1: chỉ đối chiếu con số, chạy offline không cần key
MOCK_JUDGE=0
# rỗng -> dùng lại LLM_BASE_URL/LLM_API_KEY/LLM_MODEL_LARGE ở trên
JUDGE_BASE_URL=
JUDGE_API_KEY=
JUDGE_MODEL=

# --- Langfuse (tracing + scores) — điền đủ 2 key là tự bật ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
