# Backend runtime config for the Dockerized production stack.
# Copy to be1/.env on the server (gitignored) and fill in real secrets.
# Service hostnames are the compose service names (postgres/elasticsearch/qdrant).

MOCK_LLM=0

# --- LLM (OpenAI-compatible) ---
LLM_BASE_URL=https://mkp-api.fptcloud.com
LLM_API_KEY=__LLM_API_KEY__
LLM_MODEL_SMALL=GLM-5.2
LLM_MODEL_LARGE=GLM-5.2
# Cắt cứng mỗi lần gọi model ở 5s (với stream: read-timeout giữa các chunk).
LLM_TIMEOUT_SECONDS=5

BE2_BASE_URL=
MAX_ASK_TURNS=3
COMPARE_THRESHOLD=3

# --- Elasticsearch (compose service) ---
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_PRODUCTS_INDEX=products
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_TIMEOUT_SECONDS=2

# --- PostgreSQL (compose service). Password must match deploy/.env.prod ---
DATABASE_URL=postgresql+asyncpg://be1:__POSTGRES_PASSWORD__@postgres:5432/be1
DATABASE_ECHO=0
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_RECYCLE_SECONDS=1800
LANGGRAPH_DATABASE_URL=postgresql://be1:__POSTGRES_PASSWORD__@postgres:5432/be1
LANGGRAPH_POOL_MIN_SIZE=1
LANGGRAPH_POOL_MAX_SIZE=5

# --- Auth / JWT (generate strong random 32+ byte values) ---
# nginx now terminates TLS (self-signed) in front, so we run in production mode.
# APP_ENV=production forces AUTH_COOKIE_SECURE=1; those secure cookies work over
# HTTPS. Only fall back to APP_ENV=staging if you serve plain HTTP again.
APP_ENV=production
PHONE_DEFAULT_REGION=VN
PHONE_ALLOWED_COUNTRY_CODES=84
PASSWORD_MIN_LENGTH=8
PASSWORD_MAX_LENGTH=128
LOGIN_RATE_LIMIT_WINDOW_SECONDS=900
LOGIN_PHONE_RATE_LIMIT_COUNT=5
LOGIN_IP_RATE_LIMIT_COUNT=20
AUTH_RATE_LIMIT_SECRET=__RANDOM_32B__
JWT_SECRET_KEY=__RANDOM_32B__
AUTH_TOKEN_DIGEST_SECRET=__RANDOM_32B__
JWT_ISSUER=dmx-advisor-be1
JWT_AUDIENCE=dmx-advisor-web
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000
JWT_LEEWAY_SECONDS=5

# --- CORS / cookies. Set to the public origin(s) of the deployed SPA. ---
FRONTEND_ORIGINS=https://YOUR_SERVER_IP
AUTH_ACCESS_COOKIE_NAME=dmx_access
AUTH_REFRESH_COOKIE_NAME=dmx_refresh
AUTH_COOKIE_SECURE=1
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_DOMAIN=

# --- Web search ---
WEB_SEARCH_PROVIDER=tavily
TAVILY_API_KEY=__TAVILY_API_KEY__
TAVILY_BASE_URL=https://api.tavily.com
WEB_SEARCH_MAX_RESULTS=5
WEB_SEARCH_TIMEOUT_SECONDS=20
MAX_ENRICH_ITERS=2

# --- RAG (embeddings + Qdrant compose service) ---
EMBED_MODEL=Vietnamese_Embedding
EMBED_BASE_URL=https://mkp-api.fptcloud.com
EMBED_API_KEY=__EMBED_API_KEY__
RAG_TOP_K=4
RAG_MIN_SCORE=0.3
QDRANT_URL=http://qdrant:6333
QDRANT_POLICY_COLLECTION=policies
QDRANT_API_KEY=
QDRANT_TIMEOUT_SECONDS=2

# --- Judge ---
JUDGE_MODEL=GLM-5.2
